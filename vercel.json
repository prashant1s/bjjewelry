{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "regions": ["bom1"],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/metals",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=900, stale-while-revalidate=300" }
      ]
    }
  ]
}
